// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Define database connection via the `DATABASE_URL` env var
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_POSTGRES_URL")
}

// Define custom output path for generated Prisma Client
generator client {
  provider = "prisma-client-js"
  output   = "lib/generated/prisma-client"
}

// Custodial wallet - server-managed wallet that can be shared across multiple connected wallets
// One custodial wallet can be linked to multiple external wallets
model CustodialWallet {
  id      String @id @default(cuid())
  address String @unique @db.VarChar(66) // Custodial wallet address (supports EVM & Starknet)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  wallet Wallet? // Encrypted keys (via userId = CustodialWallet.id)
  users  User[] // Connected wallets that use this custodial wallet

  @@index([address])
  @@map("custodial_wallets")
}

// User model - represents an external wallet that connects to the app
// Each external wallet links to ONE custodial wallet
// Multiple external wallets can share the SAME custodial wallet
model User {
  id                  String  @id @default(cuid())
  wallet_address      String  @unique @db.VarChar(66) // External wallet address (EVM or Starknet)
  custodial_wallet_id String  @map("custodial_wallet_id") // Links to custodial wallet
  sessionId           String? @map("session_id") // Browser session identifier to link multiple wallets to same custodial wallet

  // SIWE Authentication (proves external wallet authorized custodial wallet)
  siwe_message    String?   @db.Text // The SIWE message that was signed
  siwe_signature  String?   @db.Text // Signature from external wallet
  siwe_expires_at DateTime? @map("siwe_expires_at") // When the SIWE session expires

  // Gamification
  totalPoints Int @default(0) @map("total_points")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  custodialWallet   CustodialWallet @relation(fields: [custodial_wallet_id], references: [id], onDelete: Cascade)
  bets              Bet[]
  userTasks         UserTask[]
  referralsGiven    Referral[]      @relation("ReferrerUser")
  referralsReceived Referral[]      @relation("ReferredUser")

  @@index([wallet_address])
  @@index([custodial_wallet_id])
  @@index([totalPoints])
  @@index([sessionId])
  @@map("users")
}

// Server-side wallet management (separate from Ponder's onchain data)
// Stores encrypted private keys for custodial wallets
model Wallet {
  // Links to CustodialWallet.id
  custodialWalletId String @id @map("custodial_wallet_id") @db.VarChar(255)

  // Wallet address (supports EVM & Starknet, should match CustodialWallet.address)
  address String @unique @db.VarChar(66)

  // Encrypted private key (AES-256-GCM encrypted)
  encryptedPrivateKey String @map("encrypted_private_key") @db.Text

  // Unix timestamp (milliseconds) when wallet was created
  createdAt BigInt @map("created_at")

  // Cached balance in wei (as string to handle big numbers)
  balance String @default("0") @db.VarChar(78)

  // Locked balance (funds committed to pending bets) in wei
  lockedBalance String @default("0") @map("locked_balance") @db.VarChar(78)

  // Unix timestamp (milliseconds) of last transaction
  lastUsed BigInt? @map("last_used")

  // Timestamp fields for database management
  createdAtTimestamp DateTime @default(now()) @map("created_at_timestamp")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  custodialWallet CustodialWallet     @relation(fields: [custodialWalletId], references: [id], onDelete: Cascade)
  transactions    WalletTransaction[]

  @@index([address])
  @@index([lastUsed])
  @@index([createdAt])
  @@map("wallets")
}

// NOTE: Ponder manages these tables automatically:
// - account (onchain accounts)
// - transfer_event (transfer events)
// - allowance (token allowances)
// - approval_event (approval events)
// - user (onchain user stats)
// - bet (betting events)
//
// We only manage the Wallet table for server-side wallet encryption
// All betting data comes from Ponder's GraphQL API

// Transaction history for custodial wallets
model WalletTransaction {
  id                Int       @id @default(autoincrement())
  custodialWalletId String    @map("custodial_wallet_id") @db.VarChar(255)
  txHash            String?   @map("tx_hash") @db.VarChar(66)
  txType            String    @map("tx_type") @db.VarChar(50) // 'bet', 'withdraw', 'deposit', 'payout'
  amount            String    @db.VarChar(78)
  status            String    @db.VarChar(20) // 'pending', 'confirmed', 'failed'
  blockNumber       BigInt?   @map("block_number")
  gasUsed           String?   @map("gas_used") @db.VarChar(78)
  createdAt         DateTime  @default(now()) @map("created_at")
  confirmedAt       DateTime? @map("confirmed_at")

  wallet Wallet @relation(fields: [custodialWalletId], references: [custodialWalletId], onDelete: Cascade)

  @@index([custodialWalletId])
  @@index([txHash])
  @@index([createdAt])
  @@map("wallet_transactions")
}

// Off-chain provably fair bet storage
model Bet {
  id               String  @id @default(cuid())
  userId           String  @map("user_id") @db.VarChar(255)
  playerId         String  @map("player_id") @db.VarChar(66) // Wallet address (custodial wallet, supports EVM & Starknet)
  serverSeedHash   String  @map("server_seed_hash") @db.VarChar(64) // SHA256 commitment
  serverSeed       String? @map("server_seed") @db.VarChar(64) // Revealed after resolution
  clientSeed       String? @map("client_seed") @db.VarChar(64) // Optional client seed
  randomValue      String  @map("random_value") @db.VarChar(64) // SHA256(serverSeed + playerId + betId)
  gameNumber       String  @map("game_number") @db.VarChar(78) // (BigInt(randomValue) % 1e9) + 1
  wager            String  @db.VarChar(78) // Bet amount in wei
  targetMultiplier String  @map("target_multiplier") @db.VarChar(20) // Target multiplier (x100)
  limboMultiplier  String? @map("limbo_multiplier") @db.VarChar(20) // Actual result multiplier (x100)
  outcome          String  @db.VarChar(10) // 'win' or 'lose'
  payout           String  @db.VarChar(78) // Payout amount in wei
  status           String  @db.VarChar(20) // 'pending', 'processing', 'resolved' (win), 'complete' (loss), 'failed', 'pending_payout'

  // Exchange rate and USD values (for verification)
  ethPriceUsd String? @map("eth_price_usd") @db.VarChar(20) // ETH/USD price at bet time
  wagerUsd    String? @map("wager_usd") @db.VarChar(20) // Bet amount in USD
  payoutUsd   String? @map("payout_usd") @db.VarChar(20) // Payout amount in USD

  // Bet signature for verification (signed by custodial wallet)
  betSignature String? @map("bet_signature") @db.Text // Signature of bet message
  betMessage   String? @map("bet_message") @db.Text // Message that was signed (contains betId, wager, multiplier, hash, timestamp)

  signature  String?   @db.Text // Backend signature for payout verification (legacy)
  txHash     String?   @map("tx_hash") @db.VarChar(66) // Payout transaction hash
  createdAt  DateTime  @default(now()) @map("created_at")
  resolvedAt DateTime? @map("resolved_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([playerId])
  @@index([createdAt])
  @@index([status])
  @@map("bets")
}

// User task completion tracking
model UserTask {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  taskId      String    @map("task_id") @db.VarChar(50) // 'twitter_follow', 'referral'
  completed   Boolean   @default(false)
  points      Int       @default(0)
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([userId])
  @@index([taskId])
  @@map("user_tasks")
}

// Referral tracking
model Referral {
  id         String   @id @default(cuid())
  referrerId String   @map("referrer_id") // User who shared the referral link
  referredId String   @map("referred_id") // User who used the referral link
  points     Int      @default(50) // Points awarded for successful referral
  createdAt  DateTime @default(now()) @map("created_at")

  referrer User @relation("ReferrerUser", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("ReferredUser", fields: [referredId], references: [id], onDelete: Cascade)

  @@unique([referrerId, referredId]) // Prevent duplicate referrals
  @@index([referrerId])
  @@index([referredId])
  @@map("referrals")
}
